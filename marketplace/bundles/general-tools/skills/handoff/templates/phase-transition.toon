from: {source-skill}
to: {target-skill}
handoff_id: {plan_id}-{step}-{timestamp}
timestamp: {iso-timestamp}

task:
  description: {task-description}
  status: completed
  progress: 100

plan_id: {plan_id}

artifacts:
  files_created[{count}]{path,type}:
  {file1-path},{file1-type}

plan_status:
  previous_phase: {previous}
  current_phase: {current}
  progress: {overall-progress}

next_action: {what-to-do-next}
next_focus: {specific-focus-area}
