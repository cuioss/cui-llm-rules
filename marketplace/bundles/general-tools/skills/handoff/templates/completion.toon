from: {source-skill}
to: caller
handoff_id: {plan_id}-complete-{timestamp}
timestamp: {iso-timestamp}

task:
  description: {task-description}
  status: completed
  progress: 100

plan_id: {plan_id}

artifacts:
  files_created[{count}]{path,type}:
  {file1-path},{file1-type}
  files_modified[{count}]{path,changes}:
  {file2-path},{file2-changes}

summary:
  tasks_completed: {count}
  tests_passed: {count}
  coverage: {percentage}

deliverables:
  pr_url: {pr-url}
  branch: {branch-name}
  commit: {commit-hash}
