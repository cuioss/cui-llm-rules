#!/usr/bin/env python3
"""
Execution logging module for script executor.
Generated by /plan-marshall - DO NOT EDIT MANUALLY.

Provides two-tier logging:
- Plan-scoped: .plan/plans/{plan-id}/execution.log (when --plan-id provided)
- Global: .plan/logs/script-execution-YYYY-MM-DD.log (fallback)

Detailed error capture for non-zero exits includes args, stdout, stderr.
"""

import sys
from datetime import date, datetime
from pathlib import Path
from typing import Optional

# ============================================================================
# CONFIGURATION
# ============================================================================
LOG_ENABLED = True
GLOBAL_LOG_DIR = Path('.plan/logs')
MAX_OUTPUT_CAPTURE = 2000  # Max chars of stdout/stderr to capture on error

# ============================================================================
# PLAN-ID EXTRACTION
# ============================================================================

def extract_plan_id(args: list) -> Optional[str]:
    """Extract --plan-id value from argument list."""
    for i, arg in enumerate(args):
        if arg == '--plan-id' and i + 1 < len(args):
            return args[i + 1]
        if arg.startswith('--plan-id='):
            return arg.split('=', 1)[1]
    return None

# ============================================================================
# LOG FILE RESOLUTION
# ============================================================================

def get_log_file(args: list) -> Path:
    """Determine log file based on --plan-id presence."""
    plan_id = extract_plan_id(args)

    if plan_id:
        # Plan-scoped log
        plan_dir = Path(f'.plan/plans/{plan_id}')
        if plan_dir.exists():
            return plan_dir / 'execution.log'

    # Global session log (fallback)
    GLOBAL_LOG_DIR.mkdir(parents=True, exist_ok=True)
    return GLOBAL_LOG_DIR / f'script-execution-{date.today()}.log'

# ============================================================================
# LOG ENTRY FORMATTING
# ============================================================================

def format_success_entry(
    notation: str,
    subcommand: str,
    exit_code: int,
    duration: float
) -> str:
    """Format a success log entry (compact)."""
    timestamp = datetime.now().isoformat()
    return f"{timestamp}\t{notation}\t{subcommand}\t{exit_code}\t{duration:.2f}s\n"

def format_error_entry(
    notation: str,
    subcommand: str,
    exit_code: int,
    duration: float,
    args: list,
    stdout: str,
    stderr: str
) -> str:
    """Format an error log entry (detailed)."""
    timestamp = datetime.now().isoformat()

    # Truncate captured output
    stdout_truncated = stdout[:MAX_OUTPUT_CAPTURE] if stdout else ''
    stderr_truncated = stderr[:MAX_OUTPUT_CAPTURE] if stderr else ''

    # Multi-line error entry with details
    lines = [
        f"{timestamp}\t{notation}\t{subcommand}\t{exit_code}\t{duration:.2f}s\tERROR",
        f"  args: {' '.join(args)}",
    ]

    if stdout_truncated:
        lines.append(f"  stdout: {stdout_truncated.replace(chr(10), ' ')[:500]}")
    if stderr_truncated:
        lines.append(f"  stderr: {stderr_truncated.replace(chr(10), ' ')[:500]}")

    return '\n'.join(lines) + '\n'

# ============================================================================
# LOGGING API
# ============================================================================

def log_execution(
    notation: str,
    subcommand: str,
    args: list,
    exit_code: int,
    duration: float,
    stdout: str = '',
    stderr: str = ''
) -> None:
    """
    Log script execution to appropriate log file.

    - Success (exit_code == 0): Compact single-line entry
    - Error (exit_code != 0): Detailed multi-line entry with args, stdout, stderr
    """
    if not LOG_ENABLED:
        return

    try:
        log_file = get_log_file(args)

        if exit_code == 0:
            entry = format_success_entry(notation, subcommand, exit_code, duration)
        else:
            entry = format_error_entry(
                notation, subcommand, exit_code, duration,
                args, stdout, stderr
            )

        with open(log_file, 'a') as f:
            f.write(entry)

    except Exception:
        pass  # Silent failure for logging - don't break execution

# ============================================================================
# CLEANUP API (used by plan-marshall)
# ============================================================================

def cleanup_old_global_logs(max_age_days: int = 7) -> int:
    """Delete global logs older than max_age_days. Returns count deleted."""
    import time
    deleted = 0
    cutoff = time.time() - (max_age_days * 86400)

    if not GLOBAL_LOG_DIR.exists():
        return 0

    for log_file in GLOBAL_LOG_DIR.glob('script-execution-*.log'):
        try:
            if log_file.stat().st_mtime < cutoff:
                log_file.unlink()
                deleted += 1
        except Exception:
            pass

    return deleted
